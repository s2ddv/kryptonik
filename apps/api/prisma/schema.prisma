generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Chain {
  ETHEREUM
  POLYGON
  ARBITRUM
  BASE
  SOLANA
  BITCOIN
}

enum Exchange {
  COINBASE
  BINANCE
  KRAKEN
  BYBIT
}

enum SnapshotSource {
  WALLET_REFRESH
  SCHEDULED
  MANUAL
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets             Wallet[]
  watchlists          Watchlist[]
  snapshots           PortfolioSnapshot[]
  exchangeConnections ExchangeConnection[]

  @@map("users")
}

model Wallet {
  id       String  @id @default(uuid())
  address  String
  chain    Chain
  nickname String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assets WalletAsset[]

  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, address, chain])
  @@index([userId])
  @@map("wallets")
}

model WalletAsset {
  id     String  @id @default(uuid())
  symbol String
  name   String?

  contractAddress String?

  amount   Decimal  @db.Decimal(38, 18)
  usdValue Decimal? @db.Decimal(18, 2)

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([walletId, symbol, contractAddress])
  @@index([walletId])
  @@map("wallet_assets")
}

model Watchlist {
  id   String @id @default(uuid())
  name String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items WatchlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("watchlists")
}

model WatchlistItem {
  id     String @id @default(uuid())
  coinId String

  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([watchlistId, coinId])
  @@index([watchlistId])
  @@map("watchlist_items")
}

model PortfolioSnapshot {
  id       String         @id @default(uuid())
  totalUsd Decimal        @db.Decimal(18, 2)
  source   SnapshotSource @default(WALLET_REFRESH)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("portfolio_snapshots")
}

model ExchangeConnection {
  id       String   @id @default(uuid())
  exchange Exchange

  encryptedKey    String
  encryptedSecret String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exchange])
  @@index([userId])
  @@map("exchange_connections")
}